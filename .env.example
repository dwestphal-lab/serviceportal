# ============================================================
# PLENIUM Service Portal — Umgebungsvariablen
# Kopiere diese Datei nach .env und fülle die Werte aus
# ============================================================

# ── Datenbank ──────────────────────────────────────────────
POSTGRES_USER=postgres
POSTGRES_PASSWORD=changeme_in_production
POSTGRES_DB=plenium
POSTGRES_PORT=5432

# Prisma Connection URL (wird aus obigen Werten zusammengesetzt)
DATABASE_URL=postgresql://postgres:changeme_in_production@localhost:5432/plenium

# ── Backend (Fastify) ──────────────────────────────────────
BACKEND_PORT=3001
BACKEND_HOST=0.0.0.0
NODE_ENV=development

# CORS: Erlaubte Frontend-URL
CORS_ORIGIN=http://localhost:3000

# ── Frontend (Next.js) ────────────────────────────────────
FRONTEND_PORT=3000

# Öffentliche API-URL (vom Browser aus erreichbar)
NEXT_PUBLIC_API_URL=http://localhost:3001

# ── Auth (wird später konfiguriert) ───────────────────────
# AUTH_SECRET=generate_with_openssl_rand_base64_32
# AUTH_URL=http://localhost:3000

# ── Produktion ────────────────────────────────────────────
# Für docker-compose.prod.yml:
# POSTGRES_USER=plenium_prod
# POSTGRES_PASSWORD=<sehr_sicheres_passwort>
# POSTGRES_DB=plenium_prod
# DATABASE_URL=postgresql://plenium_prod:<passwort>@postgres:5432/plenium_prod
# CORS_ORIGIN=https://your-domain.com
# NODE_ENV=production
